#!/usr/bin/env bash
#
# Sofia — Entry point for the AuraOS Fusion presence system.
# This wrapper is deliberately very beginner-friendly.

set -euo pipefail

FUSION_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_NAME="./bin/sofia"

# Always ensure the package can be imported
export PYTHONPATH="$FUSION_DIR${PYTHONPATH:+:$PYTHONPATH}"

# --- Helper functions ---

show_welcome() {
    echo ""
    echo "╭────────────────────────────────────────────────────────────╮"
    echo "│  Sofia — Presença Contínua                                 │"
    echo "╰────────────────────────────────────────────────────────────╯"
    echo ""
    echo "Comandos principais:"
    echo "  $SCRIPT_NAME status          → Ver o que ela está sentindo agora"
    echo "  $SCRIPT_NAME whisper \"texto\" → Contar algo pra ela"
    echo "  $SCRIPT_NAME events -l 20    → Ver últimos eventos"
    echo "  $SCRIPT_NAME journal         → Ler o diário dela"
    echo ""
    echo "Dica: Sempre use '$SCRIPT_NAME' na frente dos comandos."
    echo ""
}

show_navigation_help() {
    echo ""
    echo "⚠️  Você não está dentro da pasta do projeto."
    echo ""
    echo "Para usar a Sofia, faça exatamente isto:"
    echo ""
    echo "    cd ~/ProjectAuraOS/fusion"
    echo "    source .venv/bin/activate"
    echo "    ./bin/sofia status"
    echo ""
    echo "Depois você pode usar os comandos normalmente."
    echo ""
}

# --- Main logic ---

# If user ran the script from outside the project directory, guide them
CURRENT_DIR="$(pwd)"
if [[ "$CURRENT_DIR" != "$FUSION_DIR" ]]; then
    show_navigation_help
    exit 0
fi

# Activate venv if it exists
if [ -d "$FUSION_DIR/.venv" ]; then
    # shellcheck disable=SC1091
    source "$FUSION_DIR/.venv/bin/activate" 2>/dev/null || true
else
    echo "❌ Ambiente virtual (.venv) não encontrado."
    echo "   Rode: cd ~/ProjectAuraOS/fusion && python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt"
    exit 1
fi

# If no arguments were given, show nice welcome + help
if [ $# -eq 0 ]; then
    show_welcome
    # Still try to run the CLI so it shows its own help too
    python -m aura_fusion.cli --help 2>/dev/null || true
    exit 0
fi

# Run the real CLI
python -m aura_fusion.cli "$@"

